<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Evan Timmons Personal Site</title>
    <link rel="stylesheet" href="./assets/css/style.css" />
    <script>
      const savedTheme = localStorage.getItem("theme");
      const systemPrefersDark = window.matchMedia(
        "(prefers-color-scheme: dark)",
      ).matches;
      const theme = savedTheme || (systemPrefersDark ? "dark" : "light");
      document.documentElement.setAttribute("data-theme", theme);
    </script>
  </head>

  <body>
    <div id="parallax-bg"></div>
    <%- include("partials/header.ejs") %>

    <div class="body-content-container">
      <h1>Hi! I'm Evan.</h1>
      <img
        src="./assets/images/profile_pic.jpg"
        alt="Me on the Buckeye Trail"
        class="profile-photo"
        width="616"
        height="896"
        loading="lazy"
      />
      <p class="tagline">I'm a programmer.</p>
      <p class="tagline">I'm a musician.</p>
      <p class="bio">
        I love to travel, to share good food, and to spend time with my family.
      </p>
      <div
        title="Doom Bandname Generator"
        class="content-container"
        data-names="<%= JSON.stringify(names || []) %>"
      >
        <h2>Doom Bandname Generator</h2>
        <button id="generate-btn">Generate bandname!</button>
        <div class="bandname-container">
          <h3 id="band-name-1"></h3>
          <h3 id="band-name-2"></h3>
        </div>
      </div>
    </div>

    <%- include("partials/footer.ejs") %>
    <script src="./assets/js/script.js"></script>
  </body>
</html>
