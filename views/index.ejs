<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Evan Timmons Personal Site</title>
    <link rel="stylesheet" href="./assets/css/style.css" />
    <script>
      const savedTheme = localStorage.getItem("theme");
      const systemPrefersDark = window.matchMedia(
        "(prefers-color-scheme: dark)",
      ).matches;
      const theme = savedTheme || (systemPrefersDark ? "dark" : "light");
      document.documentElement.setAttribute("data-theme", theme);
    </script>
  </head>

  <body>
    <div id="parallax-bg"></div>
    <header>
      <nav class="navbar">
        <div class="logo">Evan Timmons</div>
        <button
          id="nav-toggle"
          class="nav-toggle"
          aria-label="Toggle navigation"
          aria-expanded="false"
        >
          &#9776;
        </button>
        <div id="nav-links" class="nav-links">
          <div class="home">
            <button class="nav-link-btn">
              <img
                src="./assets/images/home_app_icon.png"
                alt="Home Icon"
                class="icon"
                width="200"
                height="200"
              />
              <a href="./index.html">Home</a>
            </button>
          </div>
          <div class="resume">
            <button class="nav-link-btn">
              <img
                src="./assets/images/document_app_icon.png"
                alt="Document Icon"
                class="icon"
                width="200"
                height="200"
              />
              <a href="./resume/index.html">Resume</a>
            </button>
          </div>
          <div class="linkedin">
            <button class="nav-link-btn">
              <img
                src="./assets/images/linkedin_app_icon.png"
                alt="LinkedIn Icon"
                class="icon"
                width="200"
                height="200"
              />
              <a
                href="https://www.linkedin.com/in/timmonsevan/"
                target="_blank"
              >
                LinkedIn
              </a>
            </button>
          </div>
          <div class="github">
            <button class="nav-link-btn">
              <img
                src="./assets/images/github_app_icon.png"
                alt="GitHub Icon"
                class="icon"
                width="200"
                height="200"
              />
              <a href="https://www.github.com/timmonsevan" target="_blank">
                GitHub
              </a>
            </button>
          </div>
          <div class="settings-dropdown">
            <button
              id="dropdown-btn"
              class="dropdown-trigger"
              aria-haspopup="true"
              aria-expanded="false"
            >
              <img
                src="./assets/images/settings_app_icon.png"
                alt="Settings Icon"
                class="icon"
                width="2295"
                height="2295"
              />
              Settings &#9662;
            </button>
            <div id="dropdown-menu" class="dropdown-menu">
              <button
                id="theme-toggle"
                aria-label="Toggle dark mode"
                class="dark-theme-toggle"
              >
                Switch Theme
              </button>
            </div>
          </div>
        </div>
      </nav>
    </header>

    <div class="body-content-container">
      <h1>Hi! I'm Evan.</h1>
      <img
        src="./assets/images/profile_pic.jpg"
        alt="Me on the Buckeye Trail"
        class="profile-photo"
        width="616"
        height="896"
        loading="lazy"
      />
      <p class="tagline">I'm a programmer.</p>
      <p class="tagline">I'm a musician.</p>
      <p class="bio">
        I love to travel, to share good food, and to spend time with my family.
      </p>
      <div title="Doom Bandname Generator" class="content-container">
        <h2>Doom Bandname Generator</h2>
        <% if (names) { %>
        <% const firstRandomName = names[Math.floor(Math.random() *
        names.length)]; const names_copy = names.copy();
        names_copy.pop(firstRandomName); %>
        <h3><%= firstRandomName %></h3>
        <% const secondRandomName = names_copy[ Math.floor(Math.random() *
        names_copy.length) ]; %>
        <h3><%= secondRandomName %></h3>
        <% } %>
      </div>
    </div>

    <footer>
      <h2 title="Contact Info" class="contact-header">Contact Information</h2>
      <div class="contact">
        <p>Location: Centerville, OH</p>
        <p>Phone: 937-674-1033</p>
        <p>Email: timmonsevan@gmail.com</p>
      </div>
    </footer>
    <script src="./assets/js/script.js"></script>
  </body>
</html>
